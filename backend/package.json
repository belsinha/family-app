{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "npm run db:chores:migrate && npm run db:chores:seed && tsc && npm run copy-schema && node scripts/copy-spa-to-dist.mjs",
    "copy-schema": "node scripts/copy-schema.js",
    "start": "node dist/server.js",
    "db:chores:migrate": "node scripts/with-chores-db-url.mjs prisma migrate deploy",
    "db:chores:seed": "npm run db:chores:migrate && node scripts/with-chores-db-url.mjs npx tsx prisma/seed-chores.ts",
    "db:chores:seed:reset": "node scripts/chores-seed-reset.mjs",
    "db:chores:reset": "node scripts/with-chores-db-url.mjs prisma migrate reset --force",
    "test": "node --import tsx --test src/services/scoring.test.ts src/services/taskGenerator.test.ts src/services/allowance.test.ts"
  },
  "dependencies": {
    "@bitcoinerlab/secp256k1": "^1.2.0",
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.89.0",
    "bcryptjs": "^3.0.3",
    "bip32": "^5.0.1",
    "bip39": "^3.1.0",
    "bitcoinjs-lib": "^7.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pdf-parse": "1.1.1",
    "pg": "^8.11.3",
    "prisma": "^5.22.0",
    "sql.js": "^1.10.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.10.9",
    "@types/sql.js": "^1.4.9",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
